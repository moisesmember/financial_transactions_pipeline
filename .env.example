STORAGE_BACKEND=local

# Use STORAGE_BACKEND=minio para ler dados e sincronizar artefatos no MinIO.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fraud-detection
MINIO_SECURE=false

RAW_DATA_PREFIX=data/raw
ARTIFACTS_PREFIX=artifacts

# Dataset Kaggle e politica de importacao.
KAGGLE_DATASET=computingvictor/transactions-fraud-datasets
# KAGGLE_API_TOKEN=seu_token
KAGGLE_OVERWRITE=false
KAGGLE_AUTO_IMPORT=false

# Limite para treino local. Use 0 para processar o dataset completo.
TRAINING_MAX_ROWS=500000

# Threshold operacional e custos relativos de negocio.
THRESHOLD_SELECTION_STRATEGY=business_cost
THRESHOLD_ANALYSIS_START=0.08
THRESHOLD_ANALYSIS_STOP=0.30
THRESHOLD_ANALYSIS_STEP=0.01
FALSE_POSITIVE_COST=1
FALSE_NEGATIVE_COST=25

# Governanca do modelo.
LEAKAGE_ROC_AUC_WARNING=0.99
STRICT_LEAKAGE_PREVENTION=true
PROMOTE_BASELINE=false
BASELINE_OVERWRITE=false

# Mantem uma copia reproduzivel do pipeline em cada execucao historica.
TRAINING_HISTORY_SAVE_PIPELINE=true

# PostgreSQL para tracking de experimentos/MLflow.
POSTGRES_DB=mlflow
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DATABASE_URL=postgresql+psycopg://mlflow:mlflow@localhost:5432/mlflow
DATABASE_TRACKING_ENABLED=true
DATABASE_CONNECT_TIMEOUT_SECONDS=3
